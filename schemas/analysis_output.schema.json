{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "analysis_output.schema.json",
  "title": "Analysis Output",
  "type": "object",
  "required": [
    "generated_at",
    "confidence",
    "evidence_refs"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "confidence": {
      "type": "string"
    },
    "summary_bullets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compact_table": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "opportunities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "clarifying_question": {
      "type": "string"
    },
    "score_total": {
      "type": "number"
    },
    "score_band": {
      "type": "string",
      "enum": [
        "Green",
        "Yellow",
        "Red"
      ]
    },
    "confidence_reason": {
      "type": "string"
    },
    "dimension_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dimension",
          "weight",
          "score"
        ],
        "properties": {
          "dimension": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "score": {
            "type": "number"
          },
          "weighted_points": {
            "type": "number"
          },
          "drivers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "issue_count": {
      "type": "integer"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "location",
          "issue_type",
          "description",
          "severity",
          "recommended_fix",
          "evidence_refs"
        ],
        "properties": {
          "location": {
            "type": "string"
          },
          "issue_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "High",
              "Medium",
              "Low"
            ]
          },
          "recommended_fix": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "llm_postprocess": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "result_path": { "type": "string" },
        "returncode": { "type": "integer" },
        "response_text": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
